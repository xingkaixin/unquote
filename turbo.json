{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "@unquote/ui#build": {
      "outputs": []
    },
    "@unquote/web#build": {
      "outputs": ["../../dist/web/**"]
    },
    "@unquote/extension#build": {
      "outputs": ["../../dist/extension/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    }
  }
}
